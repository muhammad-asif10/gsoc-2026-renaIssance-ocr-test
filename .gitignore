# ============================================================================
# 16. WHITELIST: EXCEPTION RULES (Force-add these)
# ============================================================================

# Exception: DO commit these important files
!.gitkeep
!.gitignore
!README.md
!requirements.txt
!setup.py
!LICENSE
!config.yaml.example
!src/**/*.py
!notebooks/**/*.ipynb
!data/raw/transcriptions/